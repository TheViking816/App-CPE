{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "installCommand": "npm ci",
  "env": {
    "VITE_BASE_PATH": "/"
  },
  "crons": [
    {
      "path": "/api/cron-refresh",
      "schedule": "20 5,6,10,11 * * *"
    },
    {
      "path": "/api/cron-refresh",
      "schedule": "0,45 12,13,14 * * *"
    }
  ]
}
